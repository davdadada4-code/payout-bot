# ─── Обязательно ─────────────────────────────────────────────────────────────
BOT_TOKEN=         # Токен бота от @BotFather
ADMIN_ID=          # Ваш Telegram user ID (число). Узнать: @userinfobot

# ─── Необязательно ───────────────────────────────────────────────────────────
BOT_USERNAME=      # Username бота без @, например: MyPayoutBot
PROFIT_CHAT_ID=    # ID чата/группы куда слать профит-сообщения (число, со знаком минус)
PROFIT_THREAD_ID=  # ID ветки (топика) в том чате. Оставь пустым если нет топика

SUPPORT_LINK=https://t.me/username   # Ссылка на поддержку
RULES_TEXT=                          # Текст правил (поддерживает HTML: <b>, <i>, <code>)
